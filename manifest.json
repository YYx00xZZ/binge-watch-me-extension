{
  "manifest_version": 3,
  "name": "binge-watch-me",
  "version": "0.1.0",
  "description": "Browser companion for binge-watch-me. Controls streaming sites from your phone.",

  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "*://*.netflix.com/*",
    "http://127.0.0.1:7777/*"
  ],

  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "binge-watch-me",
    "default_popup": "setup.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}